{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Netunnel Desktop",
  "version": "2.12.4",
  "identifier": "com.netunnel.desktop",
  "build": {
    "beforeDevCommand": "pnpm build:agent && pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build:agent && pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Netunnel Desktop",
        "decorations": false,
        "visible": false,
        "width": 360,
        "height": 520,
        "minWidth": 360,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self' customprotocol: asset:",
        "connect-src": "'self' ipc: http://ipc.localhost http://tauri.localhost http: https: ws: wss:",
        "font-src": "'self'",
        "img-src": "'self' asset: http://asset.localhost blob: data: http: https:",
        "style-src": "'unsafe-inline' 'self'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "resources": ["../../netunnel-agent/agent-run.exe"]
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://git.aifuqiang.win/https://github.com/aifuqiang02/netunnel/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFFODE1OTFEOERFMzU3NUQKUldSZFYrT05IVm1Ccm9kY1BPb3JQMUREMWd1V2RFMHkvTVo2NXEvVTJITHFJSGFrSHpSQnBYOXQK"
    }
  }
}
