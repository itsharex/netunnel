{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md"],
  "watcher": {
    "ignore": ["node_modules/**", "dist/**", ".git/**", "*.log"]
  },
  "mcp": {
    "postgres": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://ai_ssh_user:ai_ssh_password@127.0.0.1:5432/netunnel?sslmode=disable"
      ],
      "enabled": true
    }
  }
}
